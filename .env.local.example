# Copy this file to .env.local and fill in your values.

# ─── Groq API Key — REQUIRED for the Celestial Oracle AI chat ────────────────
# Get yours free at https://console.groq.com/
# Keep this SECRET — never prefix with NEXT_PUBLIC_ 
GROQ_API_KEY=your_groq_api_key_here

# ─── NASA API Key (optional — for NASA Horizons extended planet data) ──────────
# Get yours free at https://api.nasa.gov/
NEXT_PUBLIC_NASA_API_KEY=DEMO_KEY

# ─── N2YO satellite tracking API (optional — real-time overhead passes) ────────
# Get yours at https://www.n2yo.com/api/
N2YO_API_KEY=your_n2yo_key_here
